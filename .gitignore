# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma / sqlite
/prisma/dev.db
/prisma/dev.db-journal
/app/generated/prisma

/app/generated/prisma

# dev database (root)
/dev.db
/dev.db-journal
/dev-clean.db
/dev-clean.db-journal

# dev logs
dev.log
dev-error.log

# electron build output
/dist-electron/

# embedded node binaries
/resources/
